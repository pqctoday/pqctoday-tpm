# syntax=docker/dockerfile:1.6
#
# pqctoday-tpm — development container
#
# Ubuntu 24.04 ships OpenSSL 3.0.x which lacks ML-KEM / ML-DSA. We build
# OpenSSL 3.6.2 from source into /opt/openssl and point libtpms + swtpm
# at it via PKG_CONFIG_PATH.
#
# Usage:
#   docker build -f docker/Dockerfile.dev -t pqctoday-tpm-dev .
#   docker run --rm -it -v "$PWD:/workspace" pqctoday-tpm-dev
#
FROM ubuntu:24.04

ARG OPENSSL_VERSION=3.6.2
ARG DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install -y --no-install-recommends \
        build-essential \
        autoconf \
        automake \
        libtool \
        pkg-config \
        libjson-glib-dev \
        libglib2.0-dev \
        libtasn1-6-dev \
        libseccomp-dev \
        libgmp-dev \
        libgnutls28-dev \
        gnutls-bin \
        net-tools \
        iproute2 \
        expect \
        gawk \
        socat \
        tpm2-tools \
        tpm2-abrmd \
        git \
        cmake \
        curl \
        ca-certificates \
        python3 \
        python3-pip \
        vim \
    && rm -rf /var/lib/apt/lists/*

# Build OpenSSL 3.6.x with default providers (ML-KEM + ML-DSA are in the
# default provider as of OpenSSL 3.5; 3.6 brings HashML-DSA variants.)
WORKDIR /tmp/openssl-build
RUN curl -fsSLO "https://github.com/openssl/openssl/releases/download/openssl-${OPENSSL_VERSION}/openssl-${OPENSSL_VERSION}.tar.gz" \
    && tar xf "openssl-${OPENSSL_VERSION}.tar.gz" \
    && cd "openssl-${OPENSSL_VERSION}" \
    && ./Configure --prefix=/opt/openssl --libdir=lib64 shared \
    && make -j"$(nproc)" \
    && make install_sw \
    && cd / \
    && rm -rf /tmp/openssl-build \
    && echo '/opt/openssl/lib64' > /etc/ld.so.conf.d/openssl.conf \
    && ldconfig

ENV PKG_CONFIG_PATH=/opt/openssl/lib64/pkgconfig
ENV PATH=/opt/openssl/bin:$PATH
ENV LD_LIBRARY_PATH=/opt/openssl/lib64

# Smoke-test the OpenSSL PQC provider surface.
RUN openssl version -a \
    && openssl list -kem-algorithms | grep -i 'ML-KEM' \
    && openssl list -signature-algorithms | grep -iE 'ML-DSA|HASH-ML-DSA' || \
       (echo "FATAL: OpenSSL ${OPENSSL_VERSION} does not expose ML-KEM / ML-DSA" && exit 1)

WORKDIR /workspace
CMD ["/bin/bash"]
